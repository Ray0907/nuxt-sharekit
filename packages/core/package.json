{
	"name": "@nuxt-sharekit/core",
	"version": "0.2.0",
	"description": "Framework-agnostic share intent engine for Nuxt ShareKit.",
	"license": "MIT",
	"author": "Ray Tien",
	"homepage": "https://github.com/Ray0907/nuxt-sharekit#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Ray0907/nuxt-sharekit.git",
		"directory": "packages/core"
	},
	"bugs": "https://github.com/Ray0907/nuxt-sharekit/issues",
	"keywords": [
		"share",
		"social",
		"typescript",
		"nuxt"
	],
	"type": "module",
	"sideEffects": false,
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "node scripts/build.mjs",
		"prepack": "pnpm build",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	}
}
