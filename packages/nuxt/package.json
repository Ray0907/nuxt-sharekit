{
	"name": "nuxt-sharekit",
	"version": "0.1.0",
	"description": "Accessible, headless-friendly social sharing for Nuxt 4.",
	"license": "MIT",
	"keywords": [
		"nuxt",
		"nuxt-module",
		"social-share",
		"accessibility",
		"headless"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"main": "./dist/module.mjs",
	"types": "./dist/types.d.mts",
	"exports": {
		".": {
			"types": "./dist/types.d.mts",
			"import": "./dist/module.mjs"
		}
	},
	"scripts": {
		"build": "nuxt-module-build build",
		"dev": "nuxt-module-build build --stub",
		"test": "vitest run",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@nuxt-sharekit/core": "workspace:*",
		"reka-ui": "2.10.1",
		"uqr": "0.1.3"
	},
	"devDependencies": {
		"@nuxt/kit": "4.5.0",
		"@nuxt/module-builder": "1.0.2",
		"@nuxt/schema": "4.5.0",
		"@nuxt/test-utils": "4.0.3",
		"@vitejs/plugin-vue": "6.0.8",
		"@vue/test-utils": "2.4.11",
		"happy-dom": "20.11.0",
		"nuxt": "4.5.0",
		"vue": "3.5.40",
		"vue-tsc": "3.3.7"
	},
	"peerDependencies": {
		"nuxt": "^4.0.0",
		"vue": "^3.5.0"
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	}
}
